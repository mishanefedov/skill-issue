#!/usr/bin/env bash
# skill-issue launcher. Lives in the plugin's bin/ (auto-added to PATH by Claude
# Code) and is the package.json `bin` target for `bun link`. Resolves its own
# real location — following symlinks — so it finds the engine no matter where
# it's invoked from.
#
# Runtime preference: the prebuilt, dependency-free bundle on Node (NO Bun
# needed) when it's present; the TypeScript source via Bun only as a dev
# fallback. So a plugin/clone that ships dist/ runs without Bun.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
	DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
	SOURCE="$(readlink "$SOURCE")"
	[[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
ROOT="$(cd "$DIR/.." >/dev/null 2>&1 && pwd)"

# Fast path: prebuilt bundle on Node — no Bun required.
if [ -f "$ROOT/dist/skill-issue.mjs" ] && command -v node >/dev/null 2>&1; then
	exec node "$ROOT/dist/skill-issue.mjs" "$@"
fi

# Dev fallback: run the TypeScript source with Bun.
if command -v bun >/dev/null 2>&1; then
	exec bun "$ROOT/src/cli.ts" "$@"
fi

echo "skill-issue needs Node (to run dist/skill-issue.mjs) or Bun (to run the source)." >&2
echo "Install Bun: curl -fsSL https://bun.sh/install | bash" >&2
exit 127
